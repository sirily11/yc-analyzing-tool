# RxLab OIDC / Auth.js
AUTH_ISSUER=https://auth.rxlab.app
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_SECRET=

# Set only for local development and automated browser tests.
DEV_BYPASS_AUTH=false

# Vercel AI Gateway
AI_GATEWAY_API_KEY=
AI_CHAT_MODEL=openai/gpt-5-mini
AI_ANALYSIS_MODEL=openai/gpt-5-mini
# Dedicated structured drafting model for final application dossiers.
AI_REPORT_MODEL=openai/gpt-5-mini
# Server-only public website research used by company analysis and final reports.
FIRECRAWL_API_KEY=
# Firecrawl account webhook secret used to authenticate crawl completion events.
FIRECRAWL_WEBHOOK_SECRET=
# Public application origin used to construct the Firecrawl webhook callback.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional offline founder enrichment concurrency controls.
FOUNDER_FETCH_CONCURRENCY=3
FOUNDER_CATEGORIZATION_CONCURRENCY=8

# Turso Cloud. Omit locally to use file:local.db.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# S3-compatible storage shared by model releases and retained chat PDFs.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=
S3_PREFIX=models
# Private chat PDFs use the same bucket under this separate object prefix.
S3_DOCUMENT_PREFIX=chat-documents
# Public custom-domain base for the bucket root, without a trailing slash.
S3_DOWNLOAD_BASE_URL=https://models.example.com

# Optional product controls
ANALYSIS_RATE_LIMIT_PER_HOUR=5
