# RxLab OIDC / Auth.js
AUTH_ISSUER=https://auth.rxlab.app
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_SECRET=

# Set only for local development and automated browser tests.
DEV_BYPASS_AUTH=false

# Vercel AI Gateway
AI_GATEWAY_API_KEY=
AI_CHAT_MODEL=openai/gpt-5-mini
# Dedicated lightweight model for asynchronous titles based on the first user message.
AI_TITLE_MODEL=openai/gpt-5-nano
AI_ANALYSIS_MODEL=openai/gpt-5-mini
# Must produce 1,536-dimensional vectors for YC semantic search.
AI_EMBEDDING_MODEL=openai/text-embedding-3-small
# Dedicated structured drafting model for final application dossiers.
AI_REPORT_MODEL=openai/gpt-5-mini
# Server-only public website research used by company analysis and final reports.
FIRECRAWL_API_KEY=
# Optional but recommended in production. Authenticates prompt background completion events.
# Without it, the report progress page polls Firecrawl's authenticated job APIs instead.
FIRECRAWL_WEBHOOK_SECRET=
# A public HTTPS origin is required only when webhooks are enabled.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional offline founder enrichment concurrency controls.
FOUNDER_FETCH_CONCURRENCY=3
FOUNDER_CATEGORIZATION_CONCURRENCY=8

# Turso Cloud. Required for the YC runtime directory, seed/sync/export, and real model activation.
# Omitting it uses file:local.db only for non-directory local app state.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# S3-compatible storage shared by model releases and retained chat PDFs.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=
S3_PREFIX=models
# Private chat PDFs use the same bucket under this separate object prefix.
S3_DOCUMENT_PREFIX=chat-documents
# Public custom-domain base for the bucket root, without a trailing slash.
S3_DOWNLOAD_BASE_URL=https://models.example.com
