{
  "name": "yc-application-signal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "data:sync": "bun run scripts/sync-yc-data.ts",
    "model:categorize": "bun run scripts/categorize-yc-data.ts",
    "model:founders": "bun run scripts/enrich-yc-founders.ts",
    "model:train": "ml/.venv/bin/python ml/train.py",
    "model:validate": "ml/.venv/bin/python ml/validate_artifacts.py",
    "model:promote": "ml/.venv/bin/python ml/validate_artifacts.py --promote",
    "model:upload": "bun run scripts/release-model.ts"
  },
  "dependencies": {
    "@ai-sdk/react": "3.0.232",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@huggingface/transformers": "4.2.0",
    "@libsql/client": "0.17.4",
    "@react-pdf/renderer": "4.5.1",
    "@rxtech-lab/authjs-rxlab": "1.6.0",
    "ai": "6.0.230",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "fflate": "0.8.3",
    "lucide-react": "0.468.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "onnxruntime-web": "1.27.0",
    "pdfjs-dist": "6.1.200",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "umap-js": "^1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "22.19.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "packageManager": "bun@1.3.9"
}
